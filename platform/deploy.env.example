# Deploy target for platform/deploy.sh.
# Copy this file to platform/deploy.env (gitignored) and fill in real values.
# NEVER commit deploy.env — it holds the internal hostname of the Docker host.

# Hostname or IP of the Docker host (reachable via SSH).
DEPLOY_HOST=docker-host.example.internal

# SSH user on the Docker host.
DEPLOY_USER=root

# Target directory — OUTSIDE the Dockge public-repo directory, so this private
# stack is not picked up by Dockge (lesson learned from the cadiz deploy).
DEPLOY_PATH=/root/stacks/halfpap-io
